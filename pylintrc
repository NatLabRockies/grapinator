[MESSAGES CONTROL]
# Disable the message, report, category or checker with the given id(s).
disable=
    missing-docstring,
    line-too-long,
    invalid-name,
    too-many-arguments,
    too-many-branches,
    too-many-statements,
    too-few-public-methods,
    no-self-use,
    duplicate-code,
    import-error,
    # Uncomment to disable specific warnings entirely:
    C, R, W

[REPORTS]
# Set the output format
output-format=colorized

[BASIC]
# Good variable names for, say, short loops
good-names=i,j,k,ex,Run,_

[FORMAT]
# Maximum number of characters on a single line.
max-line-length=120

[DESIGN]
# Maximum number of locals for function / method body
max-locals=20
# Maximum number of branch for function / method body
max-branches=20

